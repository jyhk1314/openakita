  "version": "1.0.0",
  "description": "LLM dual-registration demo: registers ollama_native api_type and ollama vendor registry",
  "author": "Synapse Team",
  "license": "MIT",
  "type": "python",
  "entry": "plugin.py",
  "permissions": ["llm.register", "config.read", "config.write", "hooks.basic"],
  "requires": {
    "synapse": ">=1.5.0",
    "plugin_api": "~1",
    "python": ">=3.11"
  },
  "provides": {"llm_provider": {"api_type": "ollama_native", "registry_slug": "ollama"}},
  "category": "llm",
  "tags": ["demo", "llm", "ollama"]
